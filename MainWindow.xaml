<Window x:Class="BeitKnesetDisplay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BeitKnesetDisplay.Views"
        xmlns:vm="clr-namespace:BeitKnesetDisplay.ViewModels"
        Title="Beit Kneset Display"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Black"
        FlowDirection="RightToLeft">

    <Window.Resources>

        <!-- כאשר CurrentView הוא ZmanimViewModel, יוצג ZmanimView -->
        <DataTemplate DataType="{x:Type vm:ZmanimViewModel}">
            <views:ZmanimView />
        </DataTemplate>

        <!-- כאשר CurrentView הוא MessagesViewModel, יוצג MessagesView -->
        <DataTemplate DataType="{x:Type vm:MessagesViewModel}">
            <views:MessagesView />
        </DataTemplate>

    </Window.Resources>

    <Grid>

        <!-- רקע תמונה -->
        <Grid.Background>
            <ImageBrush ImageSource="Assets/beit_mikdash.jpg"
                        Stretch="UniformToFill"
                        Opacity="1"/>
        </Grid.Background>

        <!-- שכבת כהות מעל הרקע כדי שהטקסט יהיה קריא -->
        <Border Background="#22000000" Opacity="0.1"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="110"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
        Background="#99000000"
        Padding="10">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- שעון באמצע -->
                    <TextBlock Text="{Binding CurrentTime}"
                               FontSize="80"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center">

                        <TextBlock.Effect>
                            <DropShadowEffect Color="Gold"
                                              BlurRadius="20"
                                              ShadowDepth="0"
                                              Opacity="1"/>
                        </TextBlock.Effect>

                    </TextBlock>

                    <!-- תאריך + פרשה מתחת -->
                    <StackPanel Grid.Row="1"
                    Orientation="Vertical"
                    HorizontalAlignment="Center"
                    Margin="0,5,0,0">

                        <TextBlock Text="{Binding HebrewDate}"
                       FontSize="24"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding Parasha}"
                       FontSize="20"
                       Foreground="#FFD4AF37"
                       HorizontalAlignment="Center"/>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- CONTENT AREA -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentView}"
                            Margin="25"/>
        </Grid>
    </Grid>
</Window>