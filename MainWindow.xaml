<Window x:Class="BeitKnesetDisplay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BeitKnesetDisplay.Views"
        xmlns:vm="clr-namespace:BeitKnesetDisplay.ViewModels"
        Title="Beit Kneset Display"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Black"
        FlowDirection="RightToLeft">

    <Window.Resources>

        <!-- כאשר CurrentView הוא ZmanimViewModel, יוצג ZmanimView -->
        <DataTemplate DataType="{x:Type vm:ZmanimViewModel}">
            <views:ZmanimView />
        </DataTemplate>

        <!-- כאשר CurrentView הוא MessagesViewModel, יוצג MessagesView -->
        <DataTemplate DataType="{x:Type vm:MessagesViewModel}">
            <views:MessagesView />
        </DataTemplate>

    </Window.Resources>

    <Grid>

        <!-- רקע תמונה -->
        <Grid.Background>
            <ImageBrush ImageSource="Assets/beit_mikdash.jpg"
                        Stretch="UniformToFill"
                        Opacity="1"/>
        </Grid.Background>

        <!-- שכבת כהות מעל הרקע כדי שהטקסט יהיה קריא -->
        <Border Background="#22000000" Opacity="0.1"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="#AA000000" Padding="10">
                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- שורה עליונה -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- שעון -->
                        <TextBlock Grid.Column="0"
                       Text="{Binding CurrentTime}"
                       FontSize="70"
                       FontWeight="Bold"
                       Foreground="#FFD700"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                        <!-- תאריך עברי -->
                        <TextBlock Grid.Column="1"
                       Text="{Binding HebrewDate}"
                       FontSize="36"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"/>

                        <!-- פרשה -->
                        <TextBlock Grid.Column="2"
                       Text="{Binding Parasha}"
                       FontSize="36"
                       FontWeight="SemiBold"
                       Foreground="#FFD700"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"/>
                    </Grid>

                    <!-- שורה תחתונה -->
                    <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">

                        <TextBlock Text="{Binding DayName}"
                       FontSize="24"
                       Foreground="LightGray"
                       Margin="10,0"/>

                        <TextBlock Text="|"
                       FontSize="24"
                       Foreground="Gray"/>

                        <TextBlock Text="{Binding GregorianDate}"
                       FontSize="24"
                       Foreground="LightGray"
                       Margin="10,0"/>

                        <TextBlock Text="|"
                       FontSize="24"
                       Foreground="Gray"/>

                        <TextBlock Text="{Binding HolidayText}"
                       FontSize="24"
                       Foreground="Orange"
                       Margin="10,0"/>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- CONTENT AREA -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentView}"
                            Margin="25"/>
        </Grid>
    </Grid>
</Window>