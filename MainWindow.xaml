<Window x:Class="BeitKnesetDisplay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BeitKnesetDisplay.Views"
        xmlns:vm="clr-namespace:BeitKnesetDisplay.ViewModels"
        Title="Beit Kneset Display"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Black"
        FlowDirection="RightToLeft">

    <Window.Resources>

        <!-- כאשר CurrentView הוא ZmanimViewModel, יוצג ZmanimView -->
        <DataTemplate DataType="{x:Type vm:ZmanimViewModel}">
            <views:ZmanimView />
        </DataTemplate>

        <!-- כאשר CurrentView הוא MessagesViewModel, יוצג MessagesView -->
        <DataTemplate DataType="{x:Type vm:MessagesViewModel}">
            <views:MessagesView />
        </DataTemplate>

    </Window.Resources>

    <Grid>

        <!-- רקע תמונה -->
        <Grid.Background>
            <ImageBrush ImageSource="Assets/beit_mikdash.jpg"
                        Stretch="UniformToFill"
                        Opacity="1"/>
        </Grid.Background>

        <!-- שכבת כהות מעל הרקע כדי שהטקסט יהיה קריא -->
        <Border Background="#22000000" Opacity="0.1"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Background="#66000000"
                    Padding="10"
                    BorderBrush="#66D4AF37"
                    BorderThickness="0,0,0,2"
                    Height="180">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- שעון גדול באמצע עם Glow -->
                    <Grid Grid.Row="0"
                            HorizontalAlignment="Center">

                        <!-- שכבת Glow -->
                        <TextBlock Text="{Binding CurrentTime}"
                       FontSize="86"
                       FontWeight="Bold"
                       Foreground="#FFD4AF37"
                       Opacity="0.75"
                       HorizontalAlignment="Center"
                       TextAlignment="Center">

                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FFD4AF37"
                                      BlurRadius="42"
                                      ShadowDepth="0"
                                      Opacity="1"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <!-- טקסט חד מעל -->
                        <TextBlock Text="{Binding CurrentTime}"
                                   FontSize="86"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   LineHeight="70"/>
                            </Grid> 

                    <!-- תאריך עברי + לועזי + יום + פרשה -->
                    <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,4,0,0">

                        <TextBlock Text="{Binding DayName}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Margin="14,0"/>

                        <TextBlock Text="|"
                       FontSize="24"
                       Foreground="#FFD4AF37"
                       Margin="8,0"/>

                        <TextBlock Text="{Binding GregorianDate}"
                       FontSize="24"
                       Foreground="White"
                       Margin="14,0"/>

                        <TextBlock Text="|"
                       FontSize="24"
                       Foreground="#FFD4AF37"
                       Margin="8,0"/>

                        <TextBlock Text="{Binding HebrewDate}"
                       FontSize="24"
                       Foreground="White"
                       Margin="14,0"/>

                        <TextBlock Text="|"
                       FontSize="24"
                       Foreground="#FFD4AF37"
                       Margin="8,0"/>

                        <TextBlock Text="{Binding Parasha}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#FFD4AF37"
                       Margin="14,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENT AREA -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentView}"
                            Margin="25"/>
        </Grid>
    </Grid>
</Window>