<Window x:Class="BeitKnesetDisplay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BeitKnesetDisplay.Views"
        xmlns:vm="clr-namespace:BeitKnesetDisplay.ViewModels"
        Title="Beit Kneset Display"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Black"
        FlowDirection="RightToLeft">

    <Window.Resources>

        <!-- כאשר CurrentView הוא ZmanimViewModel, יוצג ZmanimView -->
        <DataTemplate DataType="{x:Type vm:ZmanimViewModel}">
            <views:ZmanimView />
        </DataTemplate>

        
        <DataTemplate DataType="{x:Type vm:SoldiersViewModel}">
            <views:SoldiersView/>
        </DataTemplate>
        
    </Window.Resources>

    <Grid>

        <Image Source="/Assets/beit_mikdash.jpg"
           Stretch="UniformToFill"/>

        <!-- Overlay כהה עדין -->
        <Rectangle Fill="#22000000"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="#66000000" CornerRadius="0,0,25,25" Padding="15">
                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- שורה עליונה -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- שעון -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding CurrentTime}"
                                   FontSize="90"
                                   FontWeight="Bold"
                                   Foreground="#FFD700"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">

                            <TextBlock.Effect>
                                <DropShadowEffect
                                Color="#FFD700"
                                BlurRadius="25"
                                ShadowDepth="0"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <!-- תאריך עברי -->
                        <TextBlock Grid.Column="1"
                       Text="{Binding HebrewDate}"
                       FontSize="42"
                       FontWeight="SemiBold"
                       Foreground="#FFF8DC"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"/>

                        <!-- פרשה -->
                        <TextBlock Grid.Column="2"
                       Text="{Binding Parasha}"
                       FontSize="38"
                       FontWeight="Bold"
                       Foreground="#FFE066"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"/>
                    </Grid>

                    <!-- שורה תחתונה -->
                    <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">

                        <TextBlock Text="{Binding DayName}"
                                   FontSize="24"
                                   Foreground="#F5F5DC"
                                   Margin="10,0"/>

                        <TextBlock Text="|"
                       FontSize="24"
                       Foreground="Gray"/>

                        <TextBlock Text="{Binding GregorianDate}"
                       FontSize="24"
                       Foreground="LightGray"
                       Margin="10,0"/>

                        <TextBlock Text="|"
                       FontSize="24"
                       Foreground="Gray"/>

                        <TextBlock Text="{Binding HolidayText}"
                       FontSize="24"
                       Foreground="Orange"
                       Margin="10,0"/>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- CONTENT AREA -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentView}"
                            Margin="25"/>
        </Grid>
    </Grid>
</Window>