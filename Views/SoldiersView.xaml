<UserControl x:Class="BeitKnesetDisplay.Views.SoldiersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">

    <Grid>

        <!-- רקע מלא -->
        <Image Source="/Assets/soldiers_wall.jpg"
               Stretch="UniformToFill"/>

        <!-- שכבת כהות -->
        <Rectangle Fill="#55000000"/>

        <!-- פסוק -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#44000000"
                Padding="40"
                CornerRadius="20">

            <TextBlock Text="{Binding CurrentVerse}"
                       FontSize="72"
                       FontWeight="Bold"
                       Foreground="White"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Width="1200"/>

        </Border>

        <!-- כותרת קטנה -->
        <TextBlock Text="לשלום חיילי צה״ל וכוחות הביטחון"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,40"/>

    </Grid>

</UserControl>
