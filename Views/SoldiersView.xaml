<UserControl x:Class="BeitKnesetDisplay.Views.SoldiersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">

    <Grid>

        <!-- רקע -->
        <Image Source="/Assets/soldiers_wall.jpg"
               Stretch="UniformToFill"/>

        <!-- Overlay -->
        <Rectangle Fill="#55000000"/>

        <!-- פסוק -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#33000000"
                Padding="50"
                CornerRadius="20">

            <TextBlock Text="{Binding CurrentVerse}"
                       Foreground="White"
                       FontSize="64"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Width="1200"/>

        </Border>

    </Grid>

</UserControl>