<UserControl x:Class="BeitKnesetDisplay.Views.MainBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Grid>

        <!-- רקע -->
        <Image Source="/Assets/background1.jpg"
               Stretch="Fill"/>

        <Canvas>
            
            <!-- שעון -->
            <TextBlock Text="{Binding CurrentTime}"
               Canvas.Left="780"
               Canvas.Top="110"
               Width="330"
               FontSize="52"
               FontWeight="Bold"
               Foreground="White"
               TextAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black"
                              BlurRadius="8"
                              ShadowDepth="2"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- יום בשבוע -->
            <TextBlock Text="{Binding DayName}"
               Canvas.Left="1240"
               Canvas.Top="55"
               Width="260"
               FontSize="34"
               FontWeight="Bold"
               Foreground="#1E1A72"
               TextAlignment="Center"/>

            <!-- תאריך עברי -->
            <TextBlock Text="{Binding HebrewDate}"
               Canvas.Left="130"
               Canvas.Top="55"
               Width="320"
               FontSize="28"
               FontWeight="Bold"
               Foreground="#1E1A72"
               TextAlignment="Center"/>

            <!-- הדלקת נרות -->
            <TextBlock Text="הדלקת נרות"
               Canvas.Left="1220"
               Canvas.Top="190"
               Width="260"
               FontSize="28"
               FontWeight="Bold"
               Foreground="#1E1A72"
               TextAlignment="Center"/>

            <TextBlock Text="{Binding CandleLighting}"
               Canvas.Left="1240"
               Canvas.Top="300"
               Width="220"
               FontSize="58"
               FontWeight="Bold"
               Foreground="#2416A6"
               TextAlignment="Center"/>

            <!-- צאת שבת -->
            <TextBlock Text="יציאת שבת"
               Canvas.Left="140"
               Canvas.Top="190"
               Width="260"
               FontSize="28"
               FontWeight="Bold"
               Foreground="#1E1A72"
               TextAlignment="Center"/>

            <TextBlock Text="{Binding Havdalah}"
               Canvas.Left="160"
               Canvas.Top="300"
               Width="220"
               FontSize="58"
               FontWeight="Bold"
               Foreground="#2416A6"
               TextAlignment="Center"/>

            <!-- כותרת מסגרת מרכזית -->
            <TextBlock Text="פרשת שבוע"
               Canvas.Left="690"
               Canvas.Top="395"
               Width="550"
               FontSize="26"
               FontWeight="Bold"
               Foreground="#1E1A72"
               TextAlignment="Center"/>

            <!-- פרשה -->
            <TextBlock Text="{Binding Parasha}"
               Canvas.Left="500"
               Canvas.Top="510"
               Width="900"
               FontSize="68"
               FontWeight="Bold"
               Foreground="#2416A6"
               TextAlignment="Center"/>

            <!-- חג / ראש חודש -->
            <TextBlock Text="{Binding HolidayText}"
               Canvas.Left="530"
               Canvas.Top="690"
               Width="850"
               FontSize="48"
               FontWeight="Bold"
               Foreground="#2416A6"
               TextAlignment="Center"/>

            <!-- פס תחתון שמאל -->
            <TextBlock Text="{Binding GregorianDate}"
               Canvas.Left="150"
               Canvas.Top="930"
               Width="420"
               FontSize="30"
               FontWeight="Bold"
               Foreground="#1E1A72"
               TextAlignment="Center"/>

            <!-- פס תחתון ימין -->
            <TextBlock Text="בית הכנסת קונטרופ"
               Canvas.Left="1210"
               Canvas.Top="930"
               Width="450"
               FontSize="30"
               FontWeight="Bold"
               Foreground="#1E1A72"
               TextAlignment="Center"/>

        </Canvas>

    </Grid>

</UserControl>