<UserControl x:Class="BeitKnesetDisplay.Views.MainBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Grid>

        <!-- רקע -->
        <Image Source="/Assets/background1.jpg"
               Stretch="Fill"/>

        <Canvas>
            
            <!-- שעון -->
            <TextBlock Text="{Binding CurrentTime}"
               Canvas.Left="780"
               Canvas.Top="85"
               Width="330"
               FontSize="52"
               FontWeight="Bold"
               Foreground="White"
               TextAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black"
                              BlurRadius="8"
                              ShadowDepth="2"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- יום בשבוע -->
            <TextBlock Text="{Binding DayName}"               
                    Canvas.Left="1280"
                    Canvas.Top="48"
                    Width="350"
                   FontSize="34"
                   FontWeight="Bold"
                   Foreground="#1E1A72"
                   TextAlignment="Center"/>

            <!-- תאריך עברי -->
            <TextBlock Text="{Binding HebrewDate}"
               Canvas.Left="180"
                Canvas.Top="60"
                Width="420"
               FontSize="28"
               FontWeight="Bold"
               Foreground="#1E1A72"
               TextAlignment="Center"/>

            <!-- הדלקת נרות -->
            <StackPanel Orientation="Horizontal"
            Canvas.Left="1310"
            Canvas.Top="170">

                <TextBlock Text="הדלקת נרות"
               FontSize="30"
               FontWeight="Bold"
               Foreground="#1E1A72"
               Margin="0,0,25,0"/>

                <TextBlock Text="{Binding CandleLighting}"
               FontSize="42"
               FontWeight="Bold"
               Foreground="#2416A6"/>

            </StackPanel>

            <!-- צאת שבת -->
            <StackPanel Orientation="Horizontal"
            Canvas.Left="170"
            Canvas.Top="170">

                <TextBlock Text="יציאת שבת"
               FontSize="30"
               FontWeight="Bold"
               Foreground="#1E1A72"
               Margin="0,0,25,0"/>

                <TextBlock Text="{Binding Havdalah}"
               FontSize="42"
               FontWeight="Bold"
               Foreground="#2416A6"/>

            </StackPanel>


            <!-- כותרת מסגרת מרכזית -->
            <TextBlock Text="פרשת שבוע"
               Canvas.Left="690"
               Canvas.Top="330"
               Width="550"
               FontSize="26"
               FontWeight="Bold"
               Foreground="#1E1A72"
               TextAlignment="Center"/>

            <!-- פרשה -->
            <TextBlock Text="{Binding Parasha}"
               Canvas.Left="500"
               Canvas.Top="530"
               Width="900"
               FontSize="48"
               FontWeight="Bold"
               Foreground="#2416A6"
               TextAlignment="Center"/>

            <!-- חג / ראש חודש -->
            <TextBlock Text="{Binding HolidayText}"
               Canvas.Left="530"
               Canvas.Top="690"
               Width="850"
               FontSize="48"
               FontWeight="Bold"
               Foreground="#2416A6"
               TextAlignment="Center"/>

            <!-- פס תחתון שמאל -->
            <TextBlock Text="{Binding GregorianDate}"
               Canvas.Left="110"
               Canvas.Top="750"
               Width="520"
               FontSize="30"
               FontWeight="Bold"
               Foreground="#1E1A72"
               TextAlignment="Center"/>

            <!-- פס תחתון ימין -->
            <TextBlock Text="בית הכנסת קונטרופ"
               Canvas.Left="1010"
               Canvas.Top="750"
               Width="500"
               FontSize="30"
               FontWeight="Bold"
               Foreground="#1E1A72"
               TextAlignment="Center"/>

        </Canvas>

    </Grid>

</UserControl>