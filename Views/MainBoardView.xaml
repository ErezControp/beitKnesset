<UserControl x:Class="BeitKnesetDisplay.Views.MainBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Grid>

        <!-- רקע -->
        <Image Source="/Assets/background1.jpg"
               Stretch="Fill"/>

        <Canvas>

            <!-- שעון -->
            <TextBlock Text="{Binding CurrentTime}"
               Canvas.Left="760"
               Canvas.Top="65"
               Width="220"
               TextAlignment="Center"
               FontSize="54"
               FontWeight="Bold"
               Foreground="White">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black"
                              BlurRadius="10"
                              ShadowDepth="2"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- יום בשבוע - שמאל עליון -->
            <TextBlock Text="{Binding DayName}"
               Canvas.Left="70"
               Canvas.Top="50"
               Width="260"
               FontSize="28"
               FontWeight="Bold"
               Foreground="White"
               TextAlignment="Center"/>

            <!-- תאריך עברי - ימין עליון -->
            <TextBlock Text="{Binding HebrewDate}"
               Canvas.Left="1330"
               Canvas.Top="50"
               Width="280"
               FontSize="22"
               FontWeight="Bold"
               Foreground="White"
               TextAlignment="Center"/>

            <!-- הדלקת נרות -->
            <TextBlock Text="הדלקת נרות"
               Canvas.Left="100"
               Canvas.Top="430"
               Width="180"
               FontSize="22"
               Foreground="White"
               TextAlignment="Center"/>

            <TextBlock Text="{Binding CandleLighting}"
               Canvas.Left="100"
               Canvas.Top="470"
               Width="180"
               FontSize="38"
               FontWeight="Bold"
               Foreground="White"
               TextAlignment="Center"/>

            <!-- צאת שבת -->
            <TextBlock Text="צאת שבת"
               Canvas.Left="1480"
               Canvas.Top="430"
               Width="150"
               FontSize="22"
               Foreground="White"
               TextAlignment="Center"/>

            <TextBlock Text="{Binding Havdalah}"
               Canvas.Left="1480"
               Canvas.Top="470"
               Width="150"
               FontSize="38"
               FontWeight="Bold"
               Foreground="White"
               TextAlignment="Center"/>

            <!-- פרשה במרכז -->
            <TextBlock Text="{Binding Parasha}"
               Canvas.Left="460"
               Canvas.Top="560"
               Width="950"
               FontSize="52"
               FontWeight="Bold"
               Foreground="#FFD700"
               TextAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black"
                              BlurRadius="15"
                              ShadowDepth="2"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- חג -->
            <TextBlock Text="{Binding HolidayText}"
               Canvas.Left="100"
               Canvas.Top="900"
               Width="300"
               FontSize="24"
               Foreground="White"/>

            <!-- תאריך לועזי -->
            <TextBlock Text="{Binding GregorianDate}"
               Canvas.Left="1450"
               Canvas.Top="900"
               Width="200"
               FontSize="24"
               Foreground="White"
               TextAlignment="Center"/>

        </Canvas>

    </Grid>

</UserControl>