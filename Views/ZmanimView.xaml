<UserControl x:Class="BeitKnesetDisplay.Views.ZmanimView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             FlowDirection="RightToLeft">

    <Grid Margin="60">

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!-- טור ימין -->
        <StackPanel Grid.Column="0" Margin="20">

            <Border Background="#AA000000" CornerRadius="12" Padding="20" Margin="0,10">
                <StackPanel>
                    <TextBlock Text="נץ החמה"
                               FontSize="28"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Sunrise}"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="Gold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="#AA000000" CornerRadius="12" Padding="20" Margin="0,10">
                <StackPanel>
                    <TextBlock Text="חצות"
                               FontSize="28"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Chatzot}"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="Gold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="#AA000000" CornerRadius="12" Padding="20" Margin="0,10">
                <StackPanel>
                    <TextBlock Text="מנחה גדולה"
                               FontSize="28"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding MinchaGedola}"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="Gold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- טור שמאל -->
        <StackPanel Grid.Column="1" Margin="20">

            <Border Background="#AA000000" CornerRadius="12" Padding="20" Margin="0,10">
                <StackPanel>
                    <TextBlock Text="סוף זמן שמע"
                               FontSize="28"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding SofZmanShma}"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="Gold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="#AA000000" CornerRadius="12" Padding="20" Margin="0,10">
                <StackPanel>
                    <TextBlock Text="מנחה קטנה"
                               FontSize="28"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding MinchaKetana}"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="Gold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="#AA000000" CornerRadius="12" Padding="20" Margin="0,10">
                <StackPanel>
                    <TextBlock Text="שקיעה"
                               FontSize="28"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Sunset}"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="Gold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="#AA000000" CornerRadius="12" Padding="20" Margin="0,10">
                <StackPanel>
                    <TextBlock Text="פלג המנחה"
                               FontSize="28"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding PlagHaMincha}"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="Gold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>

    </Grid>
</UserControl>
