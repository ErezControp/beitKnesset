<UserControl x:Class="BeitKnesetDisplay.Views.ZmanimView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">

    <UserControl.Resources>

        <Style x:Key="ZmanRowStyle" TargetType="Border">
            <Setter Property="Background" Value="#66000000"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="BorderBrush" Value="#44D4AF37"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ZmanNameStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ZmanTimeStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="34"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFD4AF37"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="#45FFFFFF"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderBrush" Value="#60FFD700"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15"
                              ShadowDepth="3"
                              Color="Black"
                              Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="52"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="#AA000000"
                CornerRadius="25"
                Padding="35"
                BorderBrush="#66D4AF37"
                BorderThickness="2">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="זמני היום"
                           FontSize="46"
                           FontWeight="Bold"
                           Foreground="#FFD4AF37"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <UniformGrid Grid.Row="1"
             Columns="2"
             Margin="20">

                    <!-- נץ -->
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="נץ החמה"
                       Style="{StaticResource CardTitle}" />
                            <TextBlock Text="{Binding Sunrise}"
                       Style="{StaticResource CardValue}" />
                        </StackPanel>
                    </Border>

                    <!-- סוף זמן שמע -->
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="סוף זמן שמע"
                       Style="{StaticResource CardTitle}" />
                            <TextBlock Text="{Binding SofZmanShma}"
                       Style="{StaticResource CardValue}" />
                        </StackPanel>
                    </Border>

                    <!-- חצות -->
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="חצות"
                       Style="{StaticResource CardTitle}" />
                            <TextBlock Text="{Binding Chatzot}"
                       Style="{StaticResource CardValue}" />
                        </StackPanel>
                    </Border>

                    <!-- מנחה גדולה -->
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="מנחה גדולה"
                       Style="{StaticResource CardTitle}" />
                            <TextBlock Text="{Binding MinchaGedola}"
                       Style="{StaticResource CardValue}" />
                        </StackPanel>
                    </Border>

                    <!-- מנחה קטנה -->
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="מנחה קטנה"
                       Style="{StaticResource CardTitle}" />
                            <TextBlock Text="{Binding MinchaKetana}"
                       Style="{StaticResource CardValue}" />
                        </StackPanel>
                    </Border>

                    <!-- פלג -->
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="פלג המנחה"
                       Style="{StaticResource CardTitle}" />
                            <TextBlock Text="{Binding PlagHaMincha}"
                       Style="{StaticResource CardValue}" />
                        </StackPanel>
                    </Border>

                    <!-- שקיעה -->
                    <Border Style="{StaticResource GlassCard}">
                        <StackPanel>
                            <TextBlock Text="שקיעה"
                       Style="{StaticResource CardTitle}" />
                            <TextBlock Text="{Binding Sunset}"
                       Style="{StaticResource CardValue}" />
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
