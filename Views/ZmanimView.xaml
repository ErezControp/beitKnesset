<UserControl x:Class="BeitKnesetDisplay.Views.ZmanimView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">

    <UserControl.Resources>

        <Style x:Key="ZmanRowStyle" TargetType="Border">
            <Setter Property="Background" Value="#66000000"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="BorderBrush" Value="#44D4AF37"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ZmanNameStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ZmanTimeStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="34"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFD4AF37"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Border Background="#AA000000"
                CornerRadius="25"
                Padding="35"
                BorderBrush="#66D4AF37"
                BorderThickness="2">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="זמני היום"
                           FontSize="46"
                           FontWeight="Bold"
                           Foreground="#FFD4AF37"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- עמודה ימנית: 3 זמנים -->
                    <StackPanel Grid.Column="0">

                        <Border Style="{StaticResource ZmanRowStyle}">
                            <Grid>
                                <TextBlock Text="זריחה" Style="{StaticResource ZmanNameStyle}"/>
                                <TextBlock Text="{Binding Sunrise}" Style="{StaticResource ZmanTimeStyle}"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ZmanRowStyle}">
                            <Grid>
                                <TextBlock Text="סוף זמן שמע" Style="{StaticResource ZmanNameStyle}"/>
                                <TextBlock Text="{Binding SofZmanShma}" Style="{StaticResource ZmanTimeStyle}"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ZmanRowStyle}">
                            <Grid>
                                <TextBlock Text="חצות" Style="{StaticResource ZmanNameStyle}"/>
                                <TextBlock Text="{Binding Chatzot}" Style="{StaticResource ZmanTimeStyle}"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- עמודה שמאלית: 4 זמנים -->
                    <StackPanel Grid.Column="2">

                        <Border Style="{StaticResource ZmanRowStyle}">
                            <Grid>
                                <TextBlock Text="מנחה גדולה" Style="{StaticResource ZmanNameStyle}"/>
                                <TextBlock Text="{Binding MinchaGedola}" Style="{StaticResource ZmanTimeStyle}"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ZmanRowStyle}">
                            <Grid>
                                <TextBlock Text="מנחה קטנה" Style="{StaticResource ZmanNameStyle}"/>
                                <TextBlock Text="{Binding MinchaKetana}" Style="{StaticResource ZmanTimeStyle}"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ZmanRowStyle}">
                            <Grid>
                                <TextBlock Text="פלג המנחה" Style="{StaticResource ZmanNameStyle}"/>
                                <TextBlock Text="{Binding PlagHaMincha}" Style="{StaticResource ZmanTimeStyle}"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ZmanRowStyle}">
                            <Grid>
                                <TextBlock Text="שקיעה" Style="{StaticResource ZmanNameStyle}"/>
                                <TextBlock Text="{Binding Sunset}" Style="{StaticResource ZmanTimeStyle}"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
