<UserControl x:Class="BeitKnesetDisplay.Views.ParashaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">

    <Grid>

        <Image Source="/Assets/torah_background.png"
               Stretch="UniformToFill"/>

        <Rectangle Fill="#66000000"/>

        <StackPanel Margin="80"
                    VerticalAlignment="Center">


            <TextBlock Text="פרשת השבוע"
                       FontSize="42"
                       Foreground="#FFD700"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>

            <TextBlock Text="{Binding ParashaName}"
                       FontSize="62"
                       FontWeight="Bold"
                       Foreground="#FFD700"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"/>

            <Border Grid.Row="2"
                    Background="#55000000"
                    CornerRadius="20"
                    Padding="25"
                    Margin="0,20,0,0"
                    Height="240">

                <TextBlock Text="{Binding ParashaTopics}"
                           FontSize="34"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </Border>

            <Border Grid.Row="3"
                    Background="#44000000"
                    CornerRadius="20"
                    Padding="25"
                    Margin="0,20,0,0">

                <TextBlock Text="{Binding RebbeMessage}"
                           FontSize="30"
                           Foreground="#FFF8DC"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </Border>


        </StackPanel>

    </Grid>

</UserControl>