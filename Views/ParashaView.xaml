<UserControl x:Class="BeitKnesetDisplay.Views.ParashaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Image Source="/Assets/torah_background.png"
               Stretch="UniformToFill"/>

        <Rectangle Fill="#66000000"/>

        <StackPanel Margin="80"
                    VerticalAlignment="Center">


            <TextBlock Text="פרשת השבוע"
                       FontSize="42"
                       Foreground="#FFD700"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding ParashaName}"
                       FontSize="62"
                       FontWeight="Bold"
                       Foreground="#FFD700"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"/>

            <TextBlock Text="{Binding ParashaTopics}"
                   FontSize="32"
                   Foreground="White"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Margin="0,40,0,40"/>

            <TextBlock Text="{Binding RebbeMessage}"
                   FontSize="28"
                   Foreground="#FFF8DC"
                   TextWrapping="Wrap"
                   TextAlignment="Center"/>


        </StackPanel>

    </Grid>

</UserControl>