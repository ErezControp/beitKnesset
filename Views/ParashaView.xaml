<UserControl x:Class="BeitKnesetDisplay.Views.ParashaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Image Source="/Assets/beit_mikdash.jpg"
               Stretch="UniformToFill"/>

        <Rectangle Fill="#66000000"/>

        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="פרשת השבוע"
                       FontSize="42"
                       Foreground="#FFD700"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding Parasha}"
                       FontSize="72"
                       Foreground="White"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"/>

        </StackPanel>

    </Grid>

</UserControl>