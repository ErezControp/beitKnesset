<UserControl x:Class="BeitKnesetDisplay.Views.MessagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">

    <Grid Margin="60">

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="ברוכים הבאים לבית הכנסת"
                       FontSize="48"
                       Foreground="White"
                       Margin="0,20"
                       TextAlignment="Center"/>

            <TextBlock Text="נא לשמור על השקט בזמן התפילה"
                       FontSize="36"
                       Foreground="Gold"
                       Margin="0,20"
                       TextAlignment="Center"/>

            <TextBlock Text="נא לכבות או להשתיק טלפונים"
                       FontSize="36"
                       Foreground="Gold"
                       Margin="0,20"
                       TextAlignment="Center"/>

        </StackPanel>

    </Grid>
</UserControl>
